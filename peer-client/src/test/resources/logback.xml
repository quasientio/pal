<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="false">

	<!-- APPENDERS -->
	<appender name="stdout" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="tests" class="ch.qos.logback.core.FileAppender">
		<file>logs/tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="zookeeper" class="ch.qos.logback.core.FileAppender">
		<file>logs/zookeeper-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="kafka" class="ch.qos.logback.core.FileAppender">
		<file>logs/kafka-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>



	<!-- LOGGERS -->

	<logger name="com.ittera.cometa" level="info" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="org.apache.kafka" level="info" additivity="false">
		<appender-ref ref="kafka"/>
	</logger>

	<logger name="org.apache.zookeeper" level="info" additivity="false">
		<appender-ref ref="zookeeper"/>
	</logger>

	<root level="warn">
		<appender-ref ref="stdout"/>
	</root>

</configuration>
