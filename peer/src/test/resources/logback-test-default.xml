<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="true" scanPeriod="30 seconds">

	<!-- APPENDERS -->
	<appender name="stdout" class="${console.appender.class}">
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="kafka" class="${file.appender.class}">
		<file>${logs.dir}/kafka-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="zookeeper" class="${file.appender.class}">
		<file>${logs.dir}/zookeeper-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="tests" class="${file.appender.class}">
		<file>${logs.dir}/tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>


	<!-- LOGGERS -->
	<logger name="tests" level="debug" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="net.ittera.pal.cxn" level="debug" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="${kafka.logger.name}" level="info" additivity="false">
		<appender-ref ref="kafka"/>
	</logger>

	<logger name="${zookeeper.logger.name}" level="info" additivity="false">
		<appender-ref ref="zookeeper"/>
	</logger>

	<root level="debug">
		<appender-ref ref="tests"/>
	</root>

</configuration>
