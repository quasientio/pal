#!/bin/sh

JMX_PROPS="-Dcom.sun.management.jmxremote \
	-Djava.rmi.server.hostname=$JMX_HOST \
	-Dcom.sun.management.jmxremote.port=$JMX_PORT \
	-Dcom.sun.management.jmxremote.local.only=true \
	-Dcom.sun.management.jmxremote.authenticate=false \
	-Dcom.sun.management.jmxremote.ssl=false"

JVM_OPTS="-Xmx1024M -Xms512M -server -XX:+UseConcMarkSweepGC -XX:+AggressiveOpts -XX:+UseBiasedLocking -XX:+UseNUMA -noverify"

MAIN_ARGS="$@"

if [ "$PEER_CORE_HOME" != "" ]; then
  PEER_JAR=$PEER_CORE_HOME/target/peer-*.jar
else
  PEER_JAR=peer-*.jar
fi

java $JVM_OPTS $JMX_PROPS -jar $PEER_JAR $MAIN_ARGS
