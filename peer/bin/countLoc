#!/bin/bash

echo "   SOURCES LOC"
echo "   ==========="
wc -l `find src/main -type f ! -name Wrappers.java ! -name Primitives.java ! -name Calls.java ! -name Exceptions.java ! -name Fields.java ! -name Values.java ! -name Ctxt.java ! -name Intercepts.java ! -name Exec.java ! -name Headers.java`

echo
echo "   TESTS LOC"
echo "   ==========="
wc -l `find src/test -type f`
