#!/bin/bash

if [ -z "$PAL_HOME" ]; then
  echo PAL_HOME is undefined
  exit 1
fi
if [ -z "$PAL_DIRECTORY" ]; then
  echo PAL_DIRECTORY is undefined
  exit 2
fi
if [ -z "$KAFKA_SERVERS" ]; then
  echo KAFKA_SERVERS is undefined
  exit 3
fi

pal run \
  --dir $PAL_DIRECTORY \
  --name peer-for-itt \
  --rpc 5656 \
  --jsonrpc 7789 \
  --rpc-threads 3 \
  --rpc-allow-nonpublic \
  --log auto \
  --kafka-servers $KAFKA_SERVERS \
  --interceptable \
  --classpath $PAL_HOME/itt-apps/target/itt-apps-1.0.0-SNAPSHOT.jar
