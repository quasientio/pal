#!/bin/sh

KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=9093

if ($(docker network ls | grep pal &> /dev/null ))
then
  echo '`pal` network already exists - skipping creation'
else
  docker network create pal --driver bridge
  echo 'new `pal` network created'
fi

docker container rm --volumes kafka

docker run --name kafka \
  --ulimit nofile=1024:1024 \
  --detach \
  --network pal \
  --publish 9092:9092 \
  --mount type=bind,source=$PAL_HOME/config/kafka,target=/etc/kafka \
  kafka format_start --config /etc/kafka/server.properties
