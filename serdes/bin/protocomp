#!/bin/bash

WORKING_DIR=`pwd`
SRC_DIR=$WORKING_DIR/src/main/protobuf
DST_DIR=$WORKING_DIR/src/main/java

protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/primitives.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/calls.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/fields.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/wrappers.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/exceptions.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/values.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/ctxt.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/intercepts.proto
protoc -I=$SRC_DIR --java_out=$DST_DIR $SRC_DIR/headers.proto
