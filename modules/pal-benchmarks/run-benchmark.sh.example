#-------- Generic Benchmark Params ---------
FORKS=3
JVM_ARGS_APPEND="-Xms2g -Xmx2g \
            --add-exports=java.base/jdk.internal.ref=ALL-UNNAMED \
            --add-exports=java.base/sun.nio.ch=ALL-UNNAMED \
            --add-exports=jdk.unsupported/sun.misc=ALL-UNNAMED \
            --add-exports=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED \
            --add-opens=jdk.compiler/com.sun.tools.javac=ALL-UNNAMED \
            --add-opens=java.base/java.lang=ALL-UNNAMED \
            --add-opens=java.base/java.lang.reflect=ALL-UNNAMED \
            --add-opens=java.base/java.io=ALL-UNNAMED \
            --add-opens=java.base/java.util=ALL-UNNAMED"
THREADS=8
WARMUPS=10
WARMUP_TIME=15s
ITERATIONS=15
ITER_TIME=25s

# thrpt,avgt,sample,all 
MODES=avgt,sample

#-------- Variant & IoProfile ---------
# Variants (set one or comma-separate several for comparison):
#
#   Infrastructure variants:
#     NOWEAVE              - non-woven method call (baseline, no PAL overhead)
#     NOOP                 - woven but no subsystems (quantization cost only)
#     INTERCEPTS           - intercepts enabled, none registered (infra overhead)
#     PUB                  - TCP-PUB only
#     WAL                  - Write-Ahead Log only
#     PUB_WAL              - PUB + WAL combined
#     INTERCEPTS_PUB       - Intercepts + TCP-PUB
#     INTERCEPTS_WAL       - Intercepts + WAL
#     INTERCEPTS_PUB_WAL   - Full hot path (all three)
#
#   Intercept callback variants (local no-op callbacks):
#     INTERCEPTS_BEFORE       - BEFORE intercept registered
#     INTERCEPTS_AFTER        - AFTER intercept registered
#     INTERCEPTS_AROUND       - AROUND intercept registered (chain + proceed)
#     INTERCEPTS_BEFORE_AFTER - BEFORE + AFTER intercepts registered
#     INTERCEPTS_ALL          - BEFORE + AFTER + AROUND all registered
#
#   In-flight tracking variants:
#     NOOP_IN_FLIGHT              - no intercepts, tracking only (isolate tracker cost)
#     INTERCEPTS_IN_FLIGHT        - intercepts + tracking, none registered
#     INTERCEPTS_BEFORE_IN_FLIGHT - intercepts + tracking + BEFORE registered
#
#   Async callback variants:
#     INTERCEPTS_BEFORE_ASYNC  - BEFORE_ASYNC callback (virtual threads / cached pool)
#     INTERCEPTS_AFTER_ASYNC   - AFTER_ASYNC callback (virtual threads / cached pool)
#
VARIANT=NOOP

# One of: CPU_ONLY, MOCK, REAL
IO_PROFILE=CPU_ONLY

# EXAMPLES:
# --------
# Just the matcher && callback cost
# -p variant=INTERCEPTS
# -p ioProfile=CPU_ONLY
#
# WAL serialisation cost (no network)
# -p variant=WAL
# -p ioProfile=MOCK
#
# PUB + WAL with real brokers
# -p variant=PUB_WAL
# -p ioProfile=REAL
#
# Only the quantization cost
# -p variant=NOOP
# -p ioProfile=CPU_ONLY
#
# Measure hot path only in terms of CPU -- mock network/IO
# -p variant=INTERCEPTS_PUB_WAL
# -p ioProfile=MOCK
#
# End to End, full-featured run with production-like cost
# -p variant=INTERCEPTS_PUB_WAL
# -p ioProfile=REAL
#
# --- Intercept overhead benchmarks ---
#
# Compare individual intercept types (BEFORE vs AFTER vs AROUND)
# -p variant=INTERCEPTS_BEFORE,INTERCEPTS_AFTER,INTERCEPTS_AROUND
# -p ioProfile=CPU_ONLY
#
# Full comparison: no intercepts vs each intercept type vs all combined
# -p variant=NOOP,INTERCEPTS,INTERCEPTS_BEFORE,INTERCEPTS_AFTER,INTERCEPTS_AROUND,INTERCEPTS_ALL
# -p ioProfile=CPU_ONLY
#
# Isolate in-flight tracking overhead
# -p variant=NOOP,NOOP_IN_FLIGHT,INTERCEPTS,INTERCEPTS_IN_FLIGHT
# -p ioProfile=CPU_ONLY
#
# In-flight tracking with active intercepts
# -p variant=INTERCEPTS_BEFORE,INTERCEPTS_BEFORE_IN_FLIGHT
# -p ioProfile=CPU_ONLY


#-------- Input Mode & Message type distribution ---------

# tunable payload mix: micro,small,medium,large (sum should == 100)
SIZE_DIST_PCT=40:35:20:5

# Size of payload types

# bytes in micro txt argument (default = 128)
#SIZE_MICRO_TXT=

# bytes in small txt argument (default = 2048)
#SIZE_SMALL_TXT=

# bytes in large txt argument (default = 49152)
#SIZE_LARGE_TXT=

# elements in double array argument (default = 2048)
#SIZE_ARRAY_DBL=

# input generator mode: ASYNC | PRELOADED
INPUT_MODE=PRELOADED

#-------- PUB params ---------

# One of: FIXED,CHUNKED,GROWABLE
PUB_QUEUE_TYPE=FIXED
PUB_QUEUE_INITIAL=$((16 * 1024))
PUB_QUEUE_MAX=$((1 * 1024 * 1024))
PUB_QUEUE_CHUNK=$((8 * 1024))

PUB_ENDPOINT=tcp://127.0.0.1:7899
PUB_SPSC_SIZE=$((1 << 19))
PUB_BATCH_SIZE=$((4 * 1024))
PUB_SNDHWM=10000
PUB_FLUSH_ON_CLOSE=false
PUB_DROP_POLICY=NONE
PUB_DROP_HWM=97
PUB_DROP_KEEP=92

#-------- WAL params ---------

# One of: NONE,FIXED,CHUNKED,GROWABLE
WAL_QUEUE_TYPE=FIXED
WAL_QUEUE_INITIAL=$((16 * 1024))
WAL_QUEUE_MAX=$((1 * 1024 * 1024))
WAL_QUEUE_CHUNK=$((8 * 1024))

WAL_TYPE=kafka
WAL_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
WAL_KAFKA_LINGER_MS=25
WAL_KAFKA_BATCH_SIZE=128000
WAL_KAFKA_COMPRESSION_TYPE=zstd
WAL_KAFKA_BUFFER_MEMORY=128000000

#WAL_TYPE=chronicle
#WAL_CHRONICLE_BASE_DIR=/data/chronicle
#WAL_CHRONICLE_ROLL_CYCLE=
#WAL_CHRONICLE_BLOCK_SIZE=
#WAL_CHRONICLE_SYNC_EVERY=

#-------- Other params ---------

WITH_DUMMY_SUB=false


# full hot path
java  -Dpeer.logging="$PAL_HOME/config/peer-logging.xml" \
      -Dbench.size.micro="$SIZE_MICRO_TXT" \
      -Dbench.size.small="$SIZE_SMALL_TXT" \
      -Dbench.size.large="$SIZE_LARGE_TXT" \
      -Dbench.size.array="$SIZE_ARRAY_DBL" \
      -Dbench.with_dummy_sub="$WITH_DUMMY_SUB" \
      -Dpub.queue.initial="$PUB_QUEUE_INITIAL" \
      -Dpub.queue.max="$PUB_QUEUE_MAX" \
      -Dpub.queue.chunk="$PUB_QUEUE_CHUNK" \
      -Dpub.endpoint="$PUB_ENDPOINT" \
      -Dpub.spsc_size="$PUB_SPSC_SIZE" \
      -Dpub.batch_size="$PUB_BATCH_SIZE" \
      -Dpub.flush_on_close="$PUB_FLUSH_ON_CLOSE" \
      -Dpub.drop.policy="$PUB_DROP_POLICY" \
      -Dpub.drop.hwm_pct="$PUB_DROP_HWM" \
      -Dpub.drop.keep_pct="$PUB_DROP_KEEP" \
      -Dpub.zmq.send_hwm="$PUB_SNDHWM" \
      -Dwal.queue.initial="$WAL_QUEUE_INITIAL" \
      -Dwal.queue.max="$WAL_QUEUE_MAX" \
      -Dwal.queue.chunk="$WAL_QUEUE_CHUNK" \
      -Dwal.type="$WAL_TYPE" \
      -Dwal.kafka.bootstrap_servers="$WAL_KAFKA_BOOTSTRAP_SERVERS" \
      -Dwal.kafka.linger_ms="$WAL_KAFKA_LINGER_MS" \
      -Dwal.kafka.batch_size="$WAL_KAFKA_BATCH_SIZE" \
      -Dwal.kafka.compression_type="$WAL_KAFKA_COMPRESSION_TYPE" \
      -Dwal.kafka.buffer_memory="$WAL_KAFKA_BUFFER_MEMORY" \
      -Dwal.chronicle.base_dir="$WAL_CHRONICLE_BASE_DIR" \
      -Dwal.chronicle.sync_every="$WAL_CHRONICLE_SYNC_EVERY" \
      -Xverify:none \
      -jar target/pal-benchmarks-1.0.0-SNAPSHOT.jar \
      DispatchBenchmark \
      -f "$FORKS" \
      -jvmArgsAppend "$JVM_ARGS_APPEND" \
      -t "$THREADS" \
      -wi "$WARMUPS" \
      -w "$WARMUP_TIME" \
      -i "$ITERATIONS" \
      -r "$ITER_TIME" \
      -bm "$MODES" \
      -p variant="$VARIANT" \
      -p ioProfile="$IO_PROFILE" \
      -p inputMode="$INPUT_MODE" \
      -p sizeDistPct="$SIZE_DIST_PCT" \
      -p pubQueueType="$PUB_QUEUE_TYPE" \
      -p walQueueType="$WAL_QUEUE_TYPE" \
      -rff out.json -rf json
