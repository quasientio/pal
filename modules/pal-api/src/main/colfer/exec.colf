package colfer

type ExecMessage struct {
	peerUuid     text
	messageId    text
	threadName   text
	currentTime  text
	dispatchSeq  uint32
	builderSeq   uint32
	responseToId text

	// oneof
	constructorCall      ConstructorCall
	instanceMethodCall   InstanceMethodCall
	classMethodCall      ClassMethodCall
	clinitCall           ClInitCall
	staticFieldGet       StaticFieldGet
	staticFieldPut       StaticFieldPut
	instanceFieldGet     InstanceFieldGet
	instanceFieldPut     InstanceFieldPut
	staticFieldPutDone   StaticFieldPutDone
	instanceFieldPutDone InstanceFieldPutDone
	raisedThrowable      RaisedThrowable
	returnValue          ReturnValue
}
