<configuration debug="false" scan="false">

    <appender name="cli" class="${file.appender.class}">
        <file>${logs.dir}/cli.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="kafka" class="${file.appender.class}">
        <file>${logs.dir}/kafka-cli.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="etcd" class="${file.appender.class}">
        <file>${logs.dir}/etcd-cli.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <logger name="io.quasient.pal" level="debug" additivity="false">
        <appender-ref ref="cli"/>
    </logger>

    <logger name="io.quasient.pal.serdes.kafka" level="info" additivity="false">
        <appender-ref ref="cli"/>
    </logger>

    <logger name="${kafka.logger.name}" level="info" additivity="false">
        <appender-ref ref="kafka"/>
    </logger>

    <logger name="${jetcd.logger.name}" level="info" additivity="false">
        <appender-ref ref="etcd"/>
    </logger>

    <root level="warn">
        <appender-ref ref="cli"/>
    </root>

</configuration>
