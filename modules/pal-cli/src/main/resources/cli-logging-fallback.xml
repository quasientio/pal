<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="FILE" class="${console.appender.class}">
        <file>${logs.dir}/cli.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="FILE"/>
    </root>

</configuration>
