<aspectj>
    <aspects>
        <aspect name="com.quasient.pal.core.FullQuantizeAspect"/>
    </aspects>

    <!-- use these options for debugging weaving: options="-verbose -debug -showWeaveInfo" -->

    <weaver options="-nowarn">

        <!-- peer classes -->
        <exclude within="com.quasient.pal.core..*"/>

        <!-- logging -->
        <exclude within="org.apache.logging..*"/>
        <exclude within="org.slf4j..*"/>

        <!-- kafka -->
        <exclude within="org.apache.kafka..*"/>
        <exclude within="kafka..*"/>
        <exclude within="net.jpountz..*"/>
        <exclude within="org.xerial.snappy..*"/>

        <!-- guava -->
        <exclude within="com.google.common..*"/>
        <exclude within="com.google.thirdparty..*"/>

        <!-- commons lang -->
        <exclude within="org.apache.commons.lang3..*"/>

        <!-- guice -->
        <exclude within="com.google.inject..*"/>
        <exclude within="org.aopalliance..*"/>

        <!-- zeromq -->
        <exclude within="org.zeromq..*"/>
        <exclude within="zmq..*"/>

        <!-- other -->
        <exclude within="com.sun..*"/>

    </weaver>
</aspectj>
