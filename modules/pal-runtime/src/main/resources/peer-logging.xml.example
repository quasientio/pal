<configuration debug="false" scan="false" scanPeriod="30 seconds">

    <!-- APPENDERS -->
    <appender name="peer" class="${file.appender.class}">
        <file>${logs.dir}/peer.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="kafka" class="${file.appender.class}">
        <file>${logs.dir}/kafka.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="etcd" class="${file.appender.class}">
        <file>${logs.dir}/etcd.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <!-- LOGGERS -->
    <logger name="io.quasient.pal.core" level="info" additivity="false">
        <appender-ref ref="peer"/>
    </logger>

    <logger name="io.quasient.pal.common" level="info" additivity="false">
        <appender-ref ref="peer"/>
    </logger>

    <logger name="io.quasient.pal.core.transport.kafka.LogReader" level="info" additivity="false">
        <appender-ref ref="peer"/>
    </logger>

    <logger name="io.quasient.pal.cxn" level="info" additivity="false">
        <appender-ref ref="peer"/>
    </logger>

    <logger name="${kafka.logger.name}" level="info" additivity="false">
        <appender-ref ref="kafka"/>
    </logger>

    <logger name="${jetcd.logger.name}" level="info" additivity="false">
        <appender-ref ref="etcd"/>
    </logger>

    <root level="warn">
        <appender-ref ref="peer"/>
    </root>

</configuration>
