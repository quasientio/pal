<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="true" scanPeriod="30 seconds">

	<property name="logs.dir" value="/PATH/TO/LOGS"/>

	<!-- APPENDERS -->
	<appender name="stdout" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="kafka" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/kafka-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="zookeeper" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/zookeeper-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="tests" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>


	<!-- LOGGERS -->

	<logger name="tests" level="debug" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="net.ittera.pal.cxn" level="debug" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="org.apache.kafka" level="warn" additivity="false">
		<appender-ref ref="kafka"/>
	</logger>

	<logger name="org.apache.zookeeper" level="warn" additivity="false">
		<appender-ref ref="zookeeper"/>
	</logger>

	<root level="warn">
		<appender-ref ref="stdout"/>
	</root>

</configuration>
