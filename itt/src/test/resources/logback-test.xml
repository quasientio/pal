<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="true" scanPeriod="30 seconds">

	<!-- APPENDERS -->
	<appender name="stdout" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %message%n</pattern>
		</encoder>
	</appender>

	<appender name="kafka" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/kafka-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %message%n</pattern>
		</encoder>
	</appender>

	<appender name="etcd" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/etcd-tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %message%n</pattern>
		</encoder>
	</appender>

	<appender name="tests" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/tests.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %message%n</pattern>
		</encoder>
	</appender>


	<!-- LOGGERS -->

	<logger name="tests" level="debug" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="com.quasient.pal" level="debug" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="com.quasient.pal.serdes" level="debug" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="com.quasient.pal.common.objects.ObjectLookupStoreBackgroundProcessor" level="warn" additivity="false">
		<appender-ref ref="tests"/>
	</logger>

	<logger name="org.apache.kafka" level="debug" additivity="false">
		<appender-ref ref="kafka"/>
	</logger>

	<logger name="io.etcd" level="debug" additivity="false">
		<appender-ref ref="etcd"/>
	</logger>

	<root level="warn">
		<appender-ref ref="stdout"/>
	</root>

</configuration>
