<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn" strict="true" monitorInterval="10">
    <Properties>
        <Property name="kafkaLog">logs/kafka-tests.log</Property>
        <Property name="testsLog">logs/tests.log</Property>
        <Property name="zookeeperLog">logs/zookeeper-tests.log</Property>
    </Properties>

    <Appenders>

        <Appender type="Console" name="stdout">
            <Layout type="PatternLayout" pattern="%m MDC%X%n"/>
        </Appender>

        <Appender type="File" name="kafka" fileName="${kafkaLog}">
            <Layout type="PatternLayout">
                <Pattern>%d %p %C{1.} [%t] %m%n</Pattern>
            </Layout>
        </Appender>

        <Appender type="File" name="tests" fileName="${testsLog}">
            <Layout type="PatternLayout">
                <Pattern>%d %p %C{1.} [%t] %m%n</Pattern>
            </Layout>
        </Appender>

        <Appender type="File" name="zookeeper" fileName="${zookeeperLog}">
            <Layout type="PatternLayout">
                <Pattern>%d %p %C{1.} [%t] %m%n</Pattern>
            </Layout>
        </Appender>
    </Appenders>

    <Loggers>
        <Logger name="tests" level="debug" additivity="false">
            <AppenderRef ref="tests"/>
        </Logger>

        <Logger name="com.ittera.cometa.client" level="debug" additivity="false">
            <AppenderRef ref="tests"/>
        </Logger>

        <Logger name="org.apache.kafka" level="warn" additivity="false">
            <AppenderRef ref="kafka"/>
        </Logger>

        <Logger name="org.apache.zookeeper" level="info" additivity="false">
            <AppenderRef ref="zookeeper"/>
        </Logger>

        <Root level="warn">
            <AppenderRef ref="stdout"/>
        </Root>
    </Loggers>

</Configuration>
