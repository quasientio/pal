#!/bin/bash

JVM_OPTS="-Xmx1024M -Xms512M -server -XX:+UseConcMarkSweepGC -XX:+AggressiveOpts -XX:+UseBiasedLocking -XX:+UseNUMA"
LTW_OPTS=""

if [[ $1 = '-ltw' ]]; then
  LTW_OPTS="-javaagent:$ASPECTJ_HOME/lib/aspectjweaver.jar"
fi

java $LTW_OPTS $JVM_OPTS com.ittera.cometa.concentrator.Concentrator
