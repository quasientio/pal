#!/bin/bash

JMX_PORT=9012
JMX_HOST=localhost

JVM_OPTS="-Xmx1024M -Xms512M -server -XX:+UseConcMarkSweepGC -XX:+AggressiveOpts -XX:+UseBiasedLocking -XX:+UseNUMA"
LTW_OPTS=""

if [[ $1 = '-ltw' ]]; then
  LTW_OPTS="-javaagent:$ASPECTJ_HOME/lib/aspectjweaver.jar"
fi

JMX_PROPS="-Dcom.sun.management.jmxremote \
	-Djava.rmi.server.hostname=$JMX_HOST \
	-Dcom.sun.management.jmxremote.port=$JMX_PORT \
	-Dcom.sun.management.jmxremote.local.only=true \
	-Dcom.sun.management.jmxremote.authenticate=false \
	-Dcom.sun.management.jmxremote.ssl=false"

java $JMX_PROPS $LTW_OPTS $JVM_OPTS com.ittera.cometa.concentrator.Concentrator "$@"
