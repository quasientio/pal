#!/usr/bin/python2

import zc.zk

ZK_URL="localhost:2181"
PEERS_ROOT="/cometa/peers"
LOGS_ROOT="/cometa/logs"

zk = zc.zk.ZooKeeper(ZK_URL)

print("Deleting peers")
peers = zk.children(PEERS_ROOT)
for peer in sorted(peers):
	zk.delete("%s/%s" % (PEERS_ROOT, peer))
	print(peer + " deleted.")

print("\nDeleting logs")
logs = zk.children(LOGS_ROOT)
for log in sorted(logs):
	logPath = "%s/%s" % (LOGS_ROOT,log)
	zk.delete_recursive(logPath)
	print(log + " recursively deleted.")

zk.close()
