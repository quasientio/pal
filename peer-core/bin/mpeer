#!/bin/bash

JMX_PORT=9012
JMX_HOST=localhost

JMX_PROPS="-Dcom.sun.management.jmxremote \
	-Djava.rmi.server.hostname=$JMX_HOST \
	-Dcom.sun.management.jmxremote.port=$JMX_PORT \
	-Dcom.sun.management.jmxremote.local.only=true \
	-Dcom.sun.management.jmxremote.authenticate=false \
	-Dcom.sun.management.jmxremote.ssl=false"

export MAVEN_OPTS="-Xmx1024M -Xms512M -server -XX:+UseConcMarkSweepGC -XX:+AggressiveOpts -XX:+UseBiasedLocking -XX:+UseNUMA -noverify $JMX_PROPS"

MAIN_ARGS="$@"

mvn exec:java -Dexec.mainClass="com.ittera.cometa.core.Main" -Dexec.args="$MAIN_ARGS"
