#!/bin/bash

JVM_OPTS="-Xmx1024M -Xms512M -server -enableassertions:com.ittera.cometa.util... -XX:+UseConcMarkSweepGC -XX:+AggressiveOpts -XX:+UseBiasedLocking -XX:+UseNUMA"

SYSTEM_PROPS=-Dlogback.configurationFile=logback-runner.xml

java $JVM_OPTS $SYSTEM_PROPS com.ittera.cometa.util.AppRunner "$@"
