<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="true" scanPeriod="30 seconds">

	<!-- APPENDERS -->
	<appender name="stdout" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="concentrator" class="ch.qos.logback.core.FileAppender">
		<file>logs/concentrator.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="kafka" class="ch.qos.logback.core.FileAppender">
		<file>logs/kafka.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="zookeeper" class="ch.qos.logback.core.FileAppender">
		<file>logs/zookeeper.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>


	<!-- LOGGERS -->

	<logger name="com.ittera.cometa.concentrator" level="info" additivity="false">
		<appender-ref ref="concentrator"/>
	</logger>

	<logger name="com.ittera.cometa.concentrator.KafkaDataMessageReader" level="info" additivity="false">
		<appender-ref ref="concentrator"/>
	</logger>

	<!-- Let's send logging of cometa.util package to the concentrator log -->
	<logger name="com.ittera.cometa.concentrator.util" level="info" additivity="false">
		<appender-ref ref="concentrator"/>
	</logger>

	<logger name="org.apache.kafka" level="info" additivity="false">
		<appender-ref ref="kafka"/>
	</logger>

	<logger name="org.apache.zookeeper" level="info" additivity="false">
		<appender-ref ref="zookeeper"/>
	</logger>

	<root level="warn">
		<appender-ref ref="stdout"/>
	</root>

</configuration>
