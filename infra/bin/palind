#!/usr/bin/env bash

# palind – run “pal run …” inside a Docker container
#
# Example:
#   palind run \
#          --dir etcd:2379 \
#          --kafka-servers kafka:9092 \
#          --name peer_one \
#          --rpc 6678 \
#          --jsonrpc 6679 \
#          -cp "$(pwd)/target/classes" \
#          net.ittera.pal.examples.HelloWorld

###############################################################################
# 0. helper paths / functions
###############################################################################
SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPTS_DIR/docker_utils.sh"       # createPalNetwork

IMAGE="pal"                                  # change tag/registry if needed
NETWORK="pal"
CONTAINER="peer"

# Predicate: does this CP element live on the host FS?
needs_mount() { [[ "$1" =~ ^/ || "$1" =~ ^\./ || "$1" =~ .*/ ]]; }

###############################################################################
# 1. walk argv, collecting mounts and rewriting class‑path flags
###############################################################################
declare -a VOLUMES NEW_ARGS
cpIndex=0

# NB: positional for‑loop so we can look ahead when we hit -c / -cp / --classpath
i=1
while (( i <= $# )); do
  arg="${!i}"
  case "$arg" in
    -c|-cp|--classpath)
      flag="$arg"
      (( i++ ))
      cpSpec="${!i}"

      IFS=':' read -ra rawParts <<< "$cpSpec"
      declare -a mappedParts

      for hostPath in "${rawParts[@]}"; do
        if needs_mount "$hostPath"; then
          abs="$(realpath "$hostPath")"
          if (( ${#rawParts[@]} == 1 )); then
            containerPath="/app/classes"
          else
            containerPath="/app/classes${cpIndex}"
          fi
          VOLUMES+=("-v" "${abs}:${containerPath}:ro")
          mappedParts+=("$containerPath")
          ((cpIndex++))
        else
          # element already valid inside container (e.g. /app/lib/foo.jar)
          mappedParts+=("$hostPath")
        fi
      done

      # rebuild the CP string for inside the container
      NEW_ARGS+=("$flag" "$(IFS=:; echo "${mappedParts[*]}")")
      ;;

    *)
      NEW_ARGS+=("$arg")
      ;;
  esac
  (( i++ ))
done

###############################################################################
# 2. handle “traditional” application logs (NOT Kafka topic names)
###############################################################################
PAL_LOGS_DIR="${PAL_LOGS_DIR:-$PWD/logs}"
mkdir -p "$PAL_LOGS_DIR"
VOLUMES+=("-v" "${PAL_LOGS_DIR}:/app/logs")

###############################################################################
# 3. launch
###############################################################################
if docker ps -q -f "name=^/${CONTAINER}$" | grep -q .; then
  log "Container '${CONTAINER}' already running"; exit 1
fi

docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
createPalNetwork

docker run --rm \
  --name "$CONTAINER" \
  --network "$NETWORK" \
  "${VOLUMES[@]}" \
  "$IMAGE" "${NEW_ARGS[@]}"
