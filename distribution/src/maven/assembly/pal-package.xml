<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">

  <id>bin</id>

  <formats>
    <format>zip</format>
    <format>tar.gz</format>
  </formats>

  <includeBaseDirectory>true</includeBaseDirectory>
  <baseDirectory>pal-${project.version}</baseDirectory>

  <!-- ───────────────────────── Files copied one-by-one ─────────────────────── -->

  <files>
    <file>
      <source>../modules/pal-cli/target/pal-${project.version}.jar</source>
      <outputDirectory>lib</outputDirectory>
    </file>
  </files>

  <!-- ───────────────────────── Bulk file sets ──────────────────────────────── -->

  <fileSets>

    <!-- top-level metadata and config -->
    <fileSet>
      <directory>..</directory>
      <includes>
        <include>README.md</include>
        <include>AUTHORS</include>
        <include>LICENSE</include>
        <include>THIRD_PARTY.md</include>
        <include>licenses/</include>
        <include>config/</include>
      </includes>
      <excludes>
        <exclude>config/**/*.xml</exclude>
        <exclude>config/.gitignore</exclude>
        <exclude>config/kafka/**</exclude>
        <exclude>licenses/APACHE_HEADER.txt</exclude>
        <exclude>licenses/THIRD_PARTY.ftl</exclude>
        <exclude>licenses/url-fixes.xml</exclude>
      </excludes>
    </fileSet>

    <!-- install script and env file -->
    <fileSet>
      <directory>src/dist</directory>
      <outputDirectory></outputDirectory>
      <includes>
        <include>install.sh</include>
        <include>.env.pal</include>
      </includes>
      <fileMode>0755</fileMode>
    </fileSet>

    <!-- unix launcher (executable) -->
    <fileSet>
      <directory>../bin</directory>
      <outputDirectory>bin</outputDirectory>
      <includes>
        <include>pal</include>
      </includes>
      <fileMode>0755</fileMode>
    </fileSet>

    <!-- windows launcher -->
    <fileSet>
      <directory>../bin</directory>
      <outputDirectory>bin</outputDirectory>
      <includes>
        <include>pal.bat</include>
      </includes>
      <lineEnding>crlf</lineEnding>
    </fileSet>

    <!-- quick-start docker infrastructure -->
    <fileSet>
      <directory>src/dist/infra</directory>
      <outputDirectory>infra</outputDirectory>
      <fileMode>0755</fileMode>
    </fileSet>

  </fileSets>
</assembly>
