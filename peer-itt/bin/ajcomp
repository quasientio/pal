#!/bin/bash

SOURCES=sources.lst

if [[ $1 = '-ltw' ]]; then
	SOURCES=sources-ltw.lst
fi

# Create jar file containing weaved classes
ajc -1.8 -argfile $SOURCES

# Install to mvn repository so it can be included as a project dependency
mvn install:install-file -Dfile=../codebase/apps.jar \
	-DgroupId=com.ittera.cometa -DartifactId=apps -Dversion=1.0-SNAPSHOT -Dpackaging=jar
