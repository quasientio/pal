#!/bin/bash

JVM_OPTS="-Xmx1024M -Xms512M -server -XX:+UseConcMarkSweepGC -XX:+AggressiveOpts -XX:+UseBiasedLocking -XX:+UseNUMA"

#SYSTEM_PROPS="-Dlogback.configurationFile=logback-runner.xml -Dpeer.allowP2P=false"
SYSTEM_PROPS="-Dlogback.configurationFile=logback-runner.xml"

java $JVM_OPTS $SYSTEM_PROPS com.ittera.cometa.AppRunner "$@"
