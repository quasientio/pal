<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">

    <modelVersion>4.0.0</modelVersion>
    <groupId>com.ittera.cometa</groupId>
    <artifactId>peer</artifactId>
    <packaging>pom</packaging>
    <version>1.0-SNAPSHOT</version>
    <name>peer</name>
    <url>http://maven.apache.org</url>

    <!-- PROPERTIES -->
    <properties>
        <aspectj.runtime.version>1.9.4</aspectj.runtime.version>
        <java.version>1.8</java.version>
    </properties>


    <!-- BUILD -->
    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>2.3.2</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <modules>
        <module>peer-common</module>
        <module>peer-core</module>
        <module>peer-aj</module>
        <module>peer-serdes</module>
        <module>peer-cxn</module>
        <module>peer-itt</module>
    </modules>

</project>
