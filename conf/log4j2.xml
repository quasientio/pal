<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn" strict="true" monitorInterval="90">
    <Properties>
        <Property name="concentratorLog">logs/concentrator.log</Property>
        <Property name="kafkaLog">logs/kafka.log</Property>
    </Properties>

    <Appenders>

        <Appender type="Console" name="stdout">
            <Layout type="PatternLayout" pattern="%m MDC%X%n"/>
        </Appender>

        <Appender type="File" name="concentrator" fileName="${concentratorLog}">
            <Layout type="PatternLayout">
                <Pattern>%d{HH:mm:ss.SSS} %-5level [%15.15t] %class{36} %L %M - %msg%xEx%n</Pattern>
            </Layout>
        </Appender>

        <Appender type="File" name="kafka" fileName="${kafkaLog}">
            <Layout type="PatternLayout">
                <Pattern>%d %p %C{1.} [%t] %m%n</Pattern>
            </Layout>
        </Appender>
    </Appenders>

    <Loggers>
        <Logger name="com.ittera.cometa.concentrator" level="trace" additivity="false">
            <AppenderRef ref="concentrator"/>
        </Logger>

        <Logger name="org.apache.kafka" level="debug" additivity="false">
            <AppenderRef ref="kafka"/>
        </Logger>

        <Root level="warn">
            <AppenderRef ref="stdout"/>
        </Root>
    </Loggers>

</Configuration>
