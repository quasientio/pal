<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="true" scanPeriod="30 seconds">

	<!-- APPENDERS -->
	<appender name="stdout" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="tools" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/tools.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="runner" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/runner.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="paldir" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/paldir.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="printer" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/printer.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="stats" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/stats.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="kafka" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/kafka.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="zookeeper" class="ch.qos.logback.core.FileAppender">
		<file>${logs.dir}/zookeeper.log</file>
		<encoder>
			<pattern>%date %level [%thread] %logger{10} %msg%n</pattern>
		</encoder>
	</appender>

	<!-- LOGGERS -->
	<logger name="net.ittera.pal.tools.runner" level="info" additivity="false">
		<appender-ref ref="runner"/>
	</logger>

	<logger name="net.ittera.pal.tools.paldir" level="info" additivity="false">
		<appender-ref ref="paldir"/>
	</logger>

	<logger name="net.ittera.pal.tools.printer" level="info" additivity="false">
		<appender-ref ref="printer"/>
	</logger>

	<logger name="net.ittera.pal.tools.stats" level="info" additivity="false">
		<appender-ref ref="stats"/>
	</logger>

	<logger name="net.ittera.pal" level="info" additivity="false">
		<appender-ref ref="tools"/>
	</logger>

	<logger name="org.apache.kafka" level="warn" additivity="false">
		<appender-ref ref="kafka"/>
	</logger>

	<logger name="org.apache.zookeeper" level="warn" additivity="false">
		<appender-ref ref="zookeeper"/>
	</logger>

	<root level="info">
		<appender-ref ref="tools"/>
	</root>

</configuration>
