<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="false">

    <appender name="cli" class="${file.appender.class}">
        <file>${logs.dir}/cli.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="kafka" class="${file.appender.class}">
        <file>${logs.dir}/kafka.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="zookeeper" class="${file.appender.class}">
        <file>${logs.dir}/zookeeper.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <logger name="net.ittera.pal" level="debug" additivity="false">
        <appender-ref ref="cli"/>
    </logger>

    <logger name="${kafka.logger.name}" level="info" additivity="false">
        <appender-ref ref="kafka"/>
    </logger>

    <logger name="${kafka.logger.name.unshaded}" level="info" additivity="false">
        <appender-ref ref="kafka"/>
    </logger>

    <logger name="${zookeeper.logger.name}" level="info" additivity="false">
        <appender-ref ref="zookeeper"/>
    </logger>

    <logger name="${zookeeper.logger.name.unshaded}" level="info" additivity="false">
        <appender-ref ref="zookeeper"/>
    </logger>

    <root level="warn">
        <!--appender-ref ref="cli"/-->
    </root>

</configuration>
