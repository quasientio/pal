<!--
    SpotBugs exclusion filter for PAL project.
    Only excludes auto-generated code that cannot be annotated.
    All other suppressions should use @SuppressFBWarnings annotations in code.
-->
<FindBugsFilter>
    <!-- Exclude Colfer-generated message classes (auto-generated, cannot modify) -->
    <Match>
        <Package name="~io\.quasient\.pal\.messages\.colfer.*"/>
    </Match>

    <!-- Exclude JMH-generated benchmark code (auto-generated, cannot modify) -->
    <Match>
        <Package name="~.*\.jmh_generated"/>
    </Match>

    <!-- Exclude quantized replay sample apps (test applications for integration tests) -->
    <Match>
        <Package name="io.quasient.foobar.apps.quantized.replay"/>
    </Match>

    <!--
        AspectJ-generated singleton instance fields.
        These are internal AspectJ implementation details that cannot be modified.
    -->
    <Match>
        <Bug pattern="MS_SHOULD_BE_FINAL,PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
        <Field name="ajc$perSingletonInstance"/>
    </Match>

</FindBugsFilter>
